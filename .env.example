# basis-gateway — example environment configuration
#
# Copy this file to .env and fill in values for your environment.
# Never commit a .env file containing real secrets or tokens.
#
# Evaluation is enabled when OIDC_ISSUER is set. When enabled, both
# OIDC_ISSUER and POLICY_PATH are required or the service will not become ready.

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=basis-gateway
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── OIDC / JWT ────────────────────────────────────────────────────────────────
# Required to enable POST /v1/evaluate.
# The issuer URL is used for OIDC discovery (/.well-known/openid-configuration)
# and for validating the `iss` claim in incoming tokens.
OIDC_ISSUER=https://your-idp.example.com/realms/your-realm

# Expected audience claim in incoming tokens. Leave unset to skip audience validation.
OIDC_AUDIENCE=basis-gateway

# Optional: override the JWKS URI when OIDC discovery is unavailable.
# OIDC_JWKS_URI=https://your-idp.example.com/realms/your-realm/protocol/openid-connect/certs

# JWKS in-memory cache TTL in seconds (default: 300).
# JWKS_CACHE_TTL_SECONDS=300

# ── Policy ────────────────────────────────────────────────────────────────────
# Required when OIDC_ISSUER is set. Path to a JSON policy file.
# The file is loaded once at startup; the service will not become ready if
# the file is missing or invalid.
POLICY_PATH=policies/default.json

# Optional: version string included in evaluation responses and audit records.
# POLICY_VERSION=v1
